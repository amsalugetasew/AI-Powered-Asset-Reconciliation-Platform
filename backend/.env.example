FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Database (MySQL)
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/finance

# AI API Keys (choose one or both)
OPENAI_API_KEY=my_groq_api_key_here
ANTHROPIC_API_KEY=my-anthropic-api-key

# AI Model Configuration
AI_PROVIDER=openai
OPENAI_MODEL=gpt-4-turbo-preview
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Confidence Thresholds
AI_MATCH_THRESHOLD=0.20
MANUAL_REVIEW_THRESHOLD=0.10

# Fuzzy Pre-filtering for AI Matching
FUZZY_PREFILTER_THRESHOLD=0.30
MIN_FUZZY_FOR_LLM=0.45
AI_TOP_K_CANDIDATES=5

# Rate Limiting (to avoid API errors)
RATE_LIMIT_DELAY=2.0
MAX_RETRIES=5

# File Upload
MAX_FILE_SIZE=50
UPLOAD_FOLDER=uploads
REPORTS_FOLDER=reports
